generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Team {
  id          String       @id @default(uuid())
  name        String       @db.VarChar(100)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  inviteCodes InviteCode[] @relation("TeamToInviteCodes")
  materials   Material[]   @relation("TeamToMaterials")
  products    Product[]    @relation("TeamToProducts")
  users       User[]       @relation("TeamToUsers")
  videoTasks  VideoTask[]  @relation("TeamToVideoTasks")
  videos      Video[]      @relation("TeamToVideos")
  virtualIps  VirtualIp[]  @relation("TeamToVirtualIps")

  @@map("teams")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique @db.VarChar(255)
  passwordHash String       @map("password_hash") @db.VarChar(255)
  nickname     String?      @db.VarChar(50)
  teamId       String?      @map("team_id")
  role         Role         @default(MEMBER)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  ipMaterials  IpMaterial[] @relation("UserToIpMaterials")
  materials    Material[]   @relation("UserToMaterials")
  products     Product[]    @relation("UserToProducts")
  team         Team?        @relation("TeamToUsers", fields: [teamId], references: [id])
  videoTasks   VideoTask[]  @relation("UserToVideoTasks")
  videos       Video[]      @relation("UserToVideos")
  virtualIps   VirtualIp[]  @relation("UserToVirtualIps")

  @@index([teamId], map: "users_team_id_fkey")
  @@map("users")
}

model InviteCode {
  id        String   @id @default(uuid())
  teamId    String   @map("team_id")
  code      String   @unique @db.VarChar(20)
  used      Boolean  @default(false)
  usedBy    String?  @map("used_by")
  expiresAt DateTime @map("expires_at") @db.DateTime(0)
  createdAt DateTime @default(now()) @map("created_at")
  team      Team     @relation("TeamToInviteCodes", fields: [teamId], references: [id])

  @@index([teamId], map: "invite_codes_team_id_fkey")
  @@map("invite_codes")
}

model VirtualIp {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  teamId           String            @map("team_id")
  nickname         String            @db.VarChar(50)
  age              Int?
  gender           Gender?
  height           Decimal?          @db.Decimal(5, 2)
  weight           Decimal?          @db.Decimal(5, 2)
  bust             Decimal?          @db.Decimal(5, 2)
  waist            Decimal?          @db.Decimal(5, 2)
  hip              Decimal?          @db.Decimal(5, 2)
  education        String?           @db.VarChar(50)
  major            String?           @db.VarChar(100)
  personality      String?           @db.VarChar(500)
  catchphrase      String?           @map("catchphrase") @db.VarChar(200)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  avatarUrl        String?           @map("avatar_url") @db.VarChar(500)
  basicSetting     String?           @db.Text
  city             String?           @db.VarChar(50)
  familyBackground String?           @map("family_background") @db.Text
  fullBodyUrl      String?           @map("full_body_url") @db.VarChar(500)
  hobbies          String?           @db.VarChar(500)
  incomeLevel      String?           @map("income_level") @db.VarChar(100)
  nineViewUrl      String?           @map("nine_view_url") @db.VarChar(500)
  occupation       String?           @db.VarChar(100)
  smallHabit       String?           @map("small_habit") @db.VarChar(500)
  threeViewUrl     String?           @map("three_view_url") @db.VarChar(500)
  ipMaterials      IpMaterial[]      @relation("VirtualIpToIpMaterials")
  videoTasks       VideoTask[]       @relation("VirtualIpToVideoTasks")
  videos           Video[]           @relation("VirtualIpToVideos")
  team             Team              @relation("TeamToVirtualIps", fields: [teamId], references: [id])
  user             User              @relation("UserToVirtualIps", fields: [userId], references: [id])
  virtualIpScenes  VirtualIpScene[]  @relation("VirtualIpToVirtualIpScenes")

  @@index([teamId], map: "virtual_ips_team_id_fkey")
  @@index([userId], map: "virtual_ips_user_id_fkey")
  @@map("virtual_ips")
}

model Material {
  id                    String            @id @default(uuid())
  userId                String?           @map("user_id")
  teamId                String?           @map("team_id")
  visibility            Visibility        @default(PERSONAL)
  type                  MaterialType
  name                  String            @db.VarChar(100)
  description           String?           @db.Text
  prompt                String?           @db.Text
  url                   String            @db.VarChar(500)
  tags                  String?
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  ipMaterials           IpMaterial[]      @relation("IpMaterialToMaterial")
  poseMovementLinks     PoseMovement[]    @relation("PoseMovementToMaterial")
  productScenes         ProductScene[]    @relation("ProductSceneToMaterial")
  team                  Team?             @relation("TeamToMaterials", fields: [teamId], references: [id])
  user                  User?             @relation("UserToMaterials", fields: [userId], references: [id])
  virtualIpScenes       VirtualIpScene[] @relation("VirtualIpSceneToMaterial")

  @@index([teamId], map: "materials_team_id_fkey")
  @@index([userId], map: "materials_user_id_fkey")
  @@map("materials")
}

model IpMaterial {
  id                 String         @id @default(uuid())
  ipId               String         @map("ip_id")
  userId             String         @map("user_id")
  type               IpMaterialType
  name               String         @db.VarChar(100)
  description        String?        @db.Text
  tags               String?
  fullBodyUrl        String?        @map("full_body_url") @db.VarChar(500)
  threeViewUrl       String?        @map("three_view_url") @db.VarChar(500)
  nineViewUrl        String?        @map("nine_view_url") @db.VarChar(500)
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  materialId         String?        @map("material_id")
  sourceIpMaterialId String?        @map("source_ip_material_id")
  ip                 VirtualIp      @relation("VirtualIpToIpMaterials", fields: [ipId], references: [id], onDelete: Cascade)
  material           Material?      @relation("IpMaterialToMaterial", fields: [materialId], references: [id])
  sourceIpMaterial   IpMaterial?    @relation("IpMaterialToSource", fields: [sourceIpMaterialId], references: [id])
  derivedMaterials   IpMaterial[]   @relation("IpMaterialToSource")
  user               User           @relation("UserToIpMaterials", fields: [userId], references: [id])

  @@index([ipId], map: "ip_materials_ip_id_fkey")
  @@index([materialId], map: "ip_materials_material_id_fkey")
  @@index([sourceIpMaterialId], map: "ip_materials_source_ip_material_id_fkey")
  @@index([userId], map: "ip_materials_user_id_fkey")
  @@map("ip_materials")
}

model Workflow {
  id          String      @id @default(uuid())
  code        String      @unique @db.VarChar(50)
  name        String      @db.VarChar(100)
  description String?     @db.Text
  version     String      @db.VarChar(20)
  config      String?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  videoTasks  VideoTask[] @relation("WorkflowToVideoTasks")

  @@map("workflows")
}

model VideoTask {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  teamId      String     @map("team_id")
  workflowId  String     @map("workflow_id")
  ipId        String?    @map("ip_id")
  status      TaskStatus @default(PENDING)
  params      String?    @db.Text
  result      String?    @db.Text
  error       String?    @db.Text
  startedAt   DateTime?  @map("started_at") @db.DateTime(0)
  completedAt DateTime?  @map("completed_at") @db.DateTime(0)
  createdAt   DateTime   @default(now()) @map("created_at")
  ip          VirtualIp? @relation("VirtualIpToVideoTasks", fields: [ipId], references: [id])
  team        Team       @relation("TeamToVideoTasks", fields: [teamId], references: [id])
  user        User       @relation("UserToVideoTasks", fields: [userId], references: [id])
  workflow    Workflow   @relation("WorkflowToVideoTasks", fields: [workflowId], references: [id])
  videos      Video[]    @relation("TaskToVideos")

  @@index([ipId], map: "video_tasks_ip_id_fkey")
  @@index([teamId], map: "video_tasks_team_id_fkey")
  @@index([userId], map: "video_tasks_user_id_fkey")
  @@index([workflowId], map: "video_tasks_workflow_id_fkey")
  @@map("video_tasks")
}

model Product {
  id               String            @id @default(uuid())
  userId           String            @map("user_id")
  teamId           String            @map("team_id")
  name             String            @db.VarChar(200)
  targetAudience   TargetAudience
  productDetails   String?           @db.Text
  displayActions   String?           @map("display_actions") @db.Text
  tags             String?
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  images           ProductImage[]    @relation("ProductToImages")
  productScenes    ProductScene[]    @relation("ProductToProductScenes")
  team             Team              @relation("TeamToProducts", fields: [teamId], references: [id])
  user             User              @relation("UserToProducts", fields: [userId], references: [id])
  videos           Video[]           @relation("ProductToVideos")

  @@index([teamId], map: "products_team_id_fkey")
  @@index([userId], map: "products_user_id_fkey")
  @@map("products")
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String  @map("product_id")
  url       String  @db.VarChar(500)
  isMain    Boolean @default(false) @map("is_main")
  order     Int     @default(0)
  product   Product @relation("ProductToImages", fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "product_images_product_id_fkey")
  @@map("product_images")
}

model ProductScene {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  materialId String   @map("material_id")
  createdAt  DateTime @default(now()) @map("created_at")
  product    Product  @relation("ProductToProductScenes", fields: [productId], references: [id], onDelete: Cascade)
  material   Material @relation("ProductSceneToMaterial", fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([productId, materialId])
  @@index([productId], map: "idx_product_scenes_product")
  @@index([materialId], map: "idx_product_scenes_material")
  @@map("product_scenes")
}

model Video {
  id        String     @id @default(uuid())
  taskId    String     @map("task_id")
  userId    String     @map("user_id")
  teamId    String     @map("team_id")
  ipId      String?    @map("ip_id")
  name      String?    @db.VarChar(100)
  url       String     @db.VarChar(500)
  thumbnail String?    @db.VarChar(500)
  prompt    String?    @db.Text
  duration  Int?
  size      BigInt?
  createdAt DateTime   @default(now()) @map("created_at")
  productId String?    @map("product_id") @db.VarChar(36)
  sceneId   String?    @map("scene_id") @db.VarChar(36)
  poseId    String?    @map("pose_id") @db.VarChar(36)
  movementId String?   @map("movement_id") @db.VarChar(36)
  firstFrameId String? @map("first_frame_id") @db.VarChar(36)
  styleImageId String? @map("style_image_id") @db.VarChar(36)
  modelImageId String? @map("model_image_id") @db.VarChar(36)
  product   Product?   @relation("ProductToVideos", fields: [productId], references: [id], onUpdate: Restrict, map: "fk_videos_product")
  ip        VirtualIp? @relation("VirtualIpToVideos", fields: [ipId], references: [id])
  task      VideoTask  @relation("TaskToVideos", fields: [taskId], references: [id])
  team      Team       @relation("TeamToVideos", fields: [teamId], references: [id])
  user      User       @relation("UserToVideos", fields: [userId], references: [id])

  @@index([productId], map: "fk_videos_product")
  @@index([ipId], map: "videos_ip_id_fkey")
  @@index([sceneId], map: "videos_scene_id_idx")
  @@index([poseId], map: "videos_pose_id_idx")
  @@index([movementId], map: "videos_movement_id_idx")
  @@index([firstFrameId], map: "videos_first_frame_id_idx")
  @@index([styleImageId], map: "videos_style_image_id_idx")
  @@index([modelImageId], map: "videos_model_image_id_idx")
  @@index([taskId], map: "videos_task_id_fkey")
  @@index([teamId], map: "videos_team_id_fkey")
  @@index([userId], map: "videos_user_id_fkey")
  @@map("videos")
}

model MovementMaterial {
  id        String   @id @default(uuid()) @db.VarChar(36)
  url       String?  @db.VarChar(500)
  content   String   @db.Text
  clothing  String?  @db.Text
  scope     String?  @db.Text
  isGeneral Boolean  @default(true) @map("is_general")
  createdAt DateTime @default(now()) @map("created_at")
  poseLinks PoseMovement[] @relation("PoseMovementToMovement")

  @@map("movement_materials")
}

model PoseMovement {
  id         String           @id @default(uuid()) @db.VarChar(36)
  poseId     String           @map("pose_id") @db.VarChar(36)
  movementId String           @map("movement_id") @db.VarChar(36)
  createdAt  DateTime         @default(now()) @map("created_at")
  pose       Material         @relation("PoseMovementToMaterial", fields: [poseId], references: [id], onDelete: Cascade)
  movement   MovementMaterial @relation("PoseMovementToMovement", fields: [movementId], references: [id], onDelete: Cascade)

  @@unique([poseId, movementId], map: "pose_movements_pose_id_movement_id_key")
  @@index([poseId], map: "idx_pose_movements_pose")
  @@index([movementId], map: "idx_pose_movements_movement")
  @@map("pose_movements")
}

enum Role {
  ADMIN
  MEMBER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Visibility {
  PUBLIC
  PERSONAL
  TEAM
}

enum MaterialType {
  SCENE
  POSE
  MAKEUP
  ACCESSORY
  OTHER
}

enum IpMaterialType {
  MAKEUP
  ACCESSORY
  CUSTOMIZED_CLOTHING
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum TargetAudience {
  MENS
  WOMENS
  KIDS
}

// Generation result tables
model ModelImage {
  id         String   @id @default(uuid()) @db.VarChar(36)
  productId  String   @map("product_id") @db.VarChar(36)
  ipId       String   @map("ip_id") @db.VarChar(36)
  url        String   @db.VarChar(500)
  prompt     String?  @db.Text
  inputHash  String   @map("input_hash") @db.VarChar(64)
  createdAt  DateTime @default(now()) @map("created_at")

  styleImages StyleImage[]

  @@unique([productId, ipId, inputHash], name: "uniq_model_images_dedup")
  @@index([productId], map: "idx_model_images_product")
  @@index([ipId], map: "idx_model_images_ip")
  @@map("model_images")
}

model StyleImage {
  id            String   @id @default(uuid()) @db.VarChar(36)
  productId     String   @map("product_id") @db.VarChar(36)
  ipId          String   @map("ip_id") @db.VarChar(36)
  modelImageId  String   @map("model_image_id") @db.VarChar(36)
  url           String   @db.VarChar(500)
  prompt        String?  @db.Text
  poseId        String?  @map("pose_id") @db.VarChar(36)
  makeupId      String?  @map("makeup_id") @db.VarChar(36)
  accessoryId   String?  @map("accessory_id") @db.VarChar(36)
  inputHash     String   @map("input_hash") @db.VarChar(64)
  createdAt     DateTime @default(now()) @map("created_at")

  modelImage   ModelImage   @relation(fields: [modelImageId], references: [id])
  firstFrames FirstFrame[]

  @@unique([modelImageId, inputHash], name: "uniq_style_images_dedup")
  @@index([productId], map: "idx_style_images_product")
  @@index([modelImageId], map: "idx_style_images_model_image")
  @@map("style_images")
}

model FirstFrame {
  id           String   @id @default(uuid()) @db.VarChar(36)
  productId    String   @map("product_id") @db.VarChar(36)
  ipId         String   @map("ip_id") @db.VarChar(36)
  styleImageId String?  @map("style_image_id") @db.VarChar(36)
  url          String   @db.VarChar(500)
  prompt       String?  @db.Text
  sceneId      String?  @map("scene_id") @db.VarChar(36)
  composition  String?  @db.VarChar(500)
  inputHash    String   @map("input_hash") @db.VarChar(64)
  createdAt    DateTime @default(now()) @map("created_at")

  styleImage   StyleImage? @relation(fields: [styleImageId], references: [id])

  @@unique([productId, ipId, sceneId, inputHash], name: "uniq_first_frames_dedup")
  @@index([productId], map: "idx_first_frames_product")
  @@index([styleImageId], map: "idx_first_frames_style_image")
  @@map("first_frames")
}

model VirtualIpScene {
  id          String    @id @default(uuid())
  virtualIpId String   @map("virtual_ip_id")
  materialId  String   @map("material_id")
  createdAt   DateTime @default(now()) @map("created_at")
  virtualIp   VirtualIp @relation("VirtualIpToVirtualIpScenes", fields: [virtualIpId], references: [id], onDelete: Cascade)
  material    Material  @relation("VirtualIpSceneToMaterial", fields: [materialId], references: [id], onDelete: Cascade)

  @@unique([virtualIpId, materialId])
  @@index([virtualIpId], map: "idx_virtual_ip_scenes_ip")
  @@index([materialId], map: "idx_virtual_ip_scenes_material")
  @@map("virtual_ip_scenes")
}
